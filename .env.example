# OAuth provider (default: github)
# Supported: github ONLY (google isn't supported anymore in the multi-user milestone)
OAUTH_PROVIDER=github

# GitHub OAuth App credentials (from https://github.com/settings/developers)
# Required when OAUTH_PROVIDER=github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth credentials (from https://console.cloud.google.com/apis/credentials)
# Required when OAUTH_PROVIDER=google
# GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# Server URL -- update with Cloudflare tunnel URL
SERVER_URL=https://themac-sketchpad.kempenich.dev

# JWT signing key -- any secret string, FastMCP derives 32-byte key via HKDF
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SIGNING_KEY=change-me-to-a-random-string

# Fernet encryption key for OAuth state at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STORAGE_ENCRYPTION_KEY=change-me-to-a-fernet-key

# Allowed Origins for MCP endpoint (comma-separated, default: https://claude.ai,https://www.claude.ai)
# ALLOWED_ORIGINS=https://claude.ai,https://www.claude.ai

# Paths for data and OAuth state (defaults work for local dev)
DATA_DIR=./data
STATE_DIR=./state

# Sketchpad file name (default: sketchpad.md)
# SKETCHPAD_FILENAME=sketchpad.md

# Per-user storage limit in bytes (default: 20000 = 20KB)
# MAX_STORAGE_USER=20000

# Global storage limit in bytes (default: 52428800 = 50MB)
# MAX_STORAGE_GLOBAL=52428800
